# Copy this file to .env and override values for your local machine.
# Do not put real cloud API keys in this file.

# LLM
INSURERAG_LLM_PROVIDER=vllm
INSURERAG_LLM_BASE_URL=http://localhost:8002/v1
INSURERAG_LLM_MODEL=Qwen/Qwen3-8B-AWQ
INSURERAG_LLM_API_KEY=EMPTY
INSURERAG_LLM_TEMPERATURE=0.2
INSURERAG_LLM_MAX_TOKENS=1024
INSURERAG_LLM_TIMEOUT_SECONDS=60
INSURERAG_LLM_HEALTH_TIMEOUT_SECONDS=3
# Qwen3 thinking 默认关闭（评测显示质量基本无影响、延迟约减半）。
INSURERAG_LLM_ENABLE_THINKING=false

# Embedding
INSURERAG_EMBEDDING_PROVIDER=bge_m3
INSURERAG_EMBEDDING_MODEL_PATH=BAAI/bge-m3
INSURERAG_EMBEDDING_LOCAL_FILES_ONLY=true

# Milvus
INSURERAG_VECTOR_DB_HOST=localhost
INSURERAG_VECTOR_DB_PORT=19530
INSURERAG_VECTOR_DB_COLLECTION=insure_rag

# Retrieval
INSURERAG_RETRIEVAL_DENSE_TOP_K=20
INSURERAG_RETRIEVAL_SPARSE_TOP_K=20
INSURERAG_RETRIEVAL_FINAL_TOP_K=5
INSURERAG_RETRIEVAL_RRF_K=60

# Reranker
INSURERAG_RERANKER_ENABLED=true
INSURERAG_RERANKER_MODEL=BAAI/bge-reranker-base
INSURERAG_RERANKER_LOCAL_FILES_ONLY=true

# OCR
INSURERAG_OCR_ENABLED=true
INSURERAG_OCR_FALLBACK_THRESHOLD=0.6
INSURERAG_OCR_MIN_TEXT_DENSITY=100

# Trace / API
INSURERAG_TRACE_ENABLED=true
INSURERAG_TRACE_OUTPUT_DIR=traces
INSURERAG_TRACE_RETENTION_DAYS=7
INSURERAG_TRACE_MAX_FILES=1000
INSURERAG_API_HOST=0.0.0.0
INSURERAG_API_PORT=8000
INSURERAG_API_AUTH_ENABLED=false
# Set this only in your private .env when API auth is enabled.
INSURERAG_API_KEY=
# Max upload size in MB (over the limit returns HTTP 413).
INSURERAG_API_MAX_UPLOAD_MB=50
# Max number of uploaded documents kept (new uploads beyond this return HTTP 400).
INSURERAG_API_MAX_UPLOADED_DOCS=20
INSURERAG_DASHBOARD_HOST=0.0.0.0
INSURERAG_DASHBOARD_PORT=8001

# Cache
INSURERAG_CACHE_ENABLED=true
INSURERAG_CACHE_BACKEND=redis
INSURERAG_CACHE_PATH=data/cache.json
INSURERAG_CACHE_REDIS_URL=redis://localhost:6379/0

# ---- Docker 场景覆盖示例（本机直接运行 Python 时请用上面的 localhost）----
# 容器内的 localhost 指向容器自身，而不是宿主机。当 API 跑在容器里、
# 而 vLLM/Milvus/Redis 跑在宿主机上时，需用 host.docker.internal 访问宿主机：
# INSURERAG_LLM_BASE_URL=http://host.docker.internal:8002/v1
# INSURERAG_VECTOR_DB_HOST=host.docker.internal
# INSURERAG_CACHE_REDIS_URL=redis://host.docker.internal:6379/0
# 若 Milvus/Redis 与 API 在同一个 compose 网络里，则用各自的 service name，例如：
# INSURERAG_VECTOR_DB_HOST=milvus-standalone
# INSURERAG_CACHE_REDIS_URL=redis://redis:6379/0
INSURERAG_CACHE_REDIS_PREFIX=insurerag:cache
INSURERAG_CACHE_FALLBACK_TO_JSON=true
INSURERAG_CACHE_TTL_SECONDS=86400
INSURERAG_CACHE_ANSWER_CACHE=true
INSURERAG_CACHE_SEARCH_CACHE=true
INSURERAG_CACHE_SEMANTIC_CACHE=true
